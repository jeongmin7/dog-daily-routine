# 하루(dog-health-tracker) 환경변수 예시.
# 실제 값은 .env에 넣으세요 (.env는 gitignore됨, 절대 커밋 X).

# Neon Postgres 연결 문자열.
# ⚠️ 마이그레이션은 풀링(-pooler) 연결에서 깨지므로 반드시 "직접(non-pooled)" 주소 사용.
DATABASE_URL="postgresql://USER:PASSWORD@HOST.neon.tech/neondb?sslmode=require"

# NextAuth(Auth.js) 세션 서명 키. 아래로 생성:
#   openssl rand -base64 32
AUTH_SECRET="여기에-openssl-rand-base64-32-결과"

# Vercel Blob(사진 일지 업로드). Vercel 프로젝트에 Blob 스토어를 연결하면
# production엔 자동 주입되고, 로컬은 토큰을 .env에 넣어야 한다.
#   생성: Vercel 대시보드 Storage → Blob, 또는 `vercel blob store add`
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_..."
