// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id String @id @default(cuid())
  email String @unique
  name String?
  password String
  createdAt DateTime @default(now())
  dogs Dog[]
  apiTokens ApiToken[]
}

model ApiToken {
  id String @id @default(cuid())
  userId String
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  name String
  tokenHash String @unique
  createdAt DateTime @default(now())
  lastUsedAt DateTime?
}

model Dog {
  id String @id @default(cuid())
  name String
  breed String?
  birthdate String?
  weight Float?
  userId String
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  archivedAt DateTime?
  records DogRecord[]
  photos Photo[]
  medications Medication[]
  diseases DogDisease[]
  measurements MeasurementSession[]
}

model Disease {
  key String @id
  name String
  metrics DiseaseMetric[]
  dogDiseases DogDisease[]
}

model DiseaseMetric {
  key String @id
  diseaseKey String
  disease Disease @relation(fields: [diseaseKey], references: [key], onDelete: Cascade)
  label String
  unit String
  inputType String
  durationSec Int?
  multiplier Int?
  alertMin Int?
  alertMax Int?
  sortOrder Int @default(0)
}

model DogDisease {
  id String @id @default(cuid())
  dogId String
  dog Dog @relation(fields: [dogId], references: [id], onDelete: Cascade)
  diseaseKey String
  disease Disease @relation(fields: [diseaseKey], references: [key], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([dogId, diseaseKey])
}

model MeasurementSession {
  id String @id @default(cuid())
  dogId String
  dog Dog @relation(fields: [dogId], references: [id], onDelete: Cascade)
  metricKey String
  value Float
  measuredAt DateTime @default(now())
}

model Medication {
  id String @id @default(cuid())
  dogId String
  dog Dog @relation(fields: [dogId], references: [id], onDelete: Cascade)
  name String
  dosage String?
  times String[]
  remainingCount Int?
  createdAt DateTime @default(now())
  doses MedicationDose[]
}

model MedicationDose {
  id String @id @default(cuid())
  medicationId String
  medication Medication @relation(fields: [medicationId], references: [id], onDelete: Cascade)
  date String
  time String
  takenAt DateTime @default(now())

  @@unique([medicationId, date, time])
}

model Photo {
  id String @id @default(cuid())
  dogId String
  dog Dog @relation(fields: [dogId], references: [id], onDelete: Cascade)
  url String
  caption String?
  createdAt DateTime @default(now())
}

model DogRecord {
  id String @id @default(cuid())
  dogId String
  dog Dog @relation(fields: [dogId], references: [id], onDelete: Cascade)
  date String
  meal Int?
  walkMin Int?
  walkKm Float?
  poop Int?
  weight Float?
  memo String?
  createdAt DateTime @default(now())
updatedAt DateTime @updatedAt
}


